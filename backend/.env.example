# Server Configuration
PORT=5000
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key
# Model id for generativelanguage.googleapis.com (override if your project lists a different id)
GEMINI_MODEL=gemini-2.0-flash

# Market Data APIs
TWELVE_DATA_API_KEY=your_twelve_data_api_key

# Angel One SmartAPI (NSE Real-time Data)
ANGEL_API_KEY=your_angel_api_key
ANGEL_CLIENT_ID=your_angel_client_id
# 4-digit trading MPIN (Angel app / terminal PIN). Required for many accounts; SmartAPI rejects web passwords with "Please enter 4 digit mpin".
ANGEL_MPIN=1234
# Optional fallback if you do not set ANGEL_MPIN (not recommended)
ANGEL_PASSWORD=your_angel_password
ANGEL_TOTP_SECRET=your_angel_totp_secret

# CORS Settings
FRONTEND_URL=http://localhost:3000
